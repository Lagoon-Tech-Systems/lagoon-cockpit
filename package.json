{
  "name": "lagoon-cockpit",
  "version": "2.1.0",
  "description": "Open-source mobile DevOps dashboard for Docker infrastructure",
  "private": true,
  "license": "AGPL-3.0-only",
  "workspaces": [
    "packages/api",
    "packages/app"
  ],
  "scripts": {
    "lint": "eslint packages/api/src packages/cli/src",
    "lint:fix": "eslint --fix packages/api/src packages/cli/src",
    "format:check": "prettier --check \"packages/api/src/**/*.js\" \"packages/cli/src/**/*.js\"",
    "format": "prettier --write \"packages/api/src/**/*.js\" \"packages/cli/src/**/*.js\"",
    "test": "npm test --workspaces --if-present",
    "test:api": "cd packages/api && npm test",
    "typecheck": "cd packages/app && npx tsc --noEmit"
  },
  "overrides": {
    "brace-expansion": "^2.0.1",
    "react-native-worklets": "0.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "expo-linking": "~55.0.9",
    "expo-server-sdk": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1"
  }
}
