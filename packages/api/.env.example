# ── Auth ──────────────────────────────────────────────────
AUTH_MODE=key                          # "key" (single-admin) or "users" (multi-user)
API_KEY=your-secret-key-here           # Used when AUTH_MODE=key
JWT_SECRET=random-64-char-string       # Used for signing JWTs
ADMIN_EMAIL=admin@example.com          # Used when AUTH_MODE=users (first-run setup)
ADMIN_PASSWORD=change-me               # Used when AUTH_MODE=users (first-run setup)

# ── Server ────────────────────────────────────────────────
PORT=3000
SERVER_NAME=Production VPS             # Display name in the mobile app

# ── Monitoring (optional) ─────────────────────────────────
ENDPOINTS=Website|https://example.com|200,API|https://api.example.com/health|200
SSL_DOMAINS=example.com,api.example.com

# ── Push Notifications (optional) ─────────────────────────
EXPO_ACCESS_TOKEN=                     # From expo.dev for push notifications

# ── Paths (auto-detected in Docker, override if needed) ──
PROC_PATH=/host/proc                   # Mounted /proc path
DOCKER_SOCKET=/var/run/docker.sock     # Docker Engine socket
DATA_DIR=/app/data                     # SQLite DB + state files
